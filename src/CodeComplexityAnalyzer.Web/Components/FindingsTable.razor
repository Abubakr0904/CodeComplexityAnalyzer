@using CodeComplexityAnalyzer.Core.Reporting
@inject Microsoft.JSInterop.IJSRuntime JS

@if (Findings is null)
{
    <div class="placeholder-card">
        Run an analysis to see findings.
    </div>
}
else
{
    var errorCount = Findings.Count(f => f.Severity == Severity.Error);
    var warningCount = Findings.Count(f => f.Severity == Severity.Warning);
    var filtered = FilteredFindings().ToList();
    var groups = BuildGroups(filtered);
    var fileCount = groups.Count;

    <div class="findings-summary">
        @if (errorCount > 0)
        {
            <span class="badge badge-error">@errorCount error@(errorCount == 1 ? "" : "s")</span>
        }
        @if (warningCount > 0)
        {
            <span class="badge badge-warning">@warningCount warning@(warningCount == 1 ? "" : "s")</span>
        }
        @if (errorCount == 0 && warningCount == 0)
        {
            <span class="badge badge-clean">No issues</span>
        }
        @if (fileCount > 0)
        {
            <span class="files-count">across @fileCount file@(fileCount == 1 ? "" : "s")</span>
        }
    </div>

    <MetricDistributionChart Findings="Findings" />

    @if (Findings!.Count == 0)
    {
        <p class="empty-state">No findings — code is within thresholds.</p>
    }
    else
    {
        <div class="findings-controls">
            <div class="filter-group">
                <span class="control-label">Severity</span>
                <button type="button" class="@FilterBtnClass(_severityFilter == SeverityFilter.Both)"
                        @onclick="() => SetSeverityFilter(SeverityFilter.Both)">All</button>
                <button type="button" class="@FilterBtnClass(_severityFilter == SeverityFilter.ErrorsOnly)"
                        @onclick="() => SetSeverityFilter(SeverityFilter.ErrorsOnly)">Errors</button>
                <button type="button" class="@FilterBtnClass(_severityFilter == SeverityFilter.WarningsOnly)"
                        @onclick="() => SetSeverityFilter(SeverityFilter.WarningsOnly)">Warnings</button>
            </div>

            <div class="filter-group">
                <span class="control-label">Metrics</span>
                @foreach (var mt in Enum.GetValues<MetricType>())
                {
                    <label class="metric-checkbox" @key="mt">
                        <input type="checkbox" checked="@_metricFilter.Contains(mt)"
                               @onchange="@(e => ToggleMetric(mt, (bool)e.Value!))" />
                        @mt
                    </label>
                }
            </div>

            <div class="filter-group">
                <span class="control-label">Sort</span>
                <select @bind="_sortOrder">
                    <option value="@SortOrder.Severity">Severity</option>
                    <option value="@SortOrder.FilePath">File path</option>
                    <option value="@SortOrder.ValueDesc">Value (desc)</option>
                </select>
            </div>

            <div class="export-group" style="margin-left:auto">
                <span class="control-label">Export</span>
                <button type="button" class="btn btn-sm"
                        @onclick="DownloadCsv"
                        disabled="@(Findings is null || Findings!.Count == 0)">
                    <Icon Name="download" Size="13" />
                    CSV
                </button>
                @if (OnExport.HasDelegate && CanExport)
                {
                    <button type="button" class="btn btn-sm"
                            @onclick='() => OnExport.InvokeAsync("json")'
                            disabled="@(Findings is null || Findings!.Count == 0)">
                        <Icon Name="download" Size="13" />
                        JSON
                    </button>
                    <button type="button" class="btn btn-sm"
                            @onclick='() => OnExport.InvokeAsync("sarif")'
                            disabled="@(Findings is null || Findings!.Count == 0)">
                        <Icon Name="download" Size="13" />
                        SARIF
                    </button>
                }
            </div>
        </div>

        @if (filtered.Count == 0)
        {
            <p class="empty-state">No findings match the current filters.</p>
        }
        else
        {
            @foreach (var group in groups)
            {
                var expanded = _expanded.Contains(group.FilePath);
                <div class="findings-group @(expanded ? "expanded" : "collapsed")" @key="group.FilePath">
                    <button type="button" class="group-header" @onclick="() => Toggle(group.FilePath)">
                        <span class="chevron">@(expanded ? "▼" : "▶")</span>
                        <span class="group-path">@group.FilePath</span>
                        <span class="group-counts">
                            @if (group.ErrorCount > 0)
                            {
                                <span class="badge badge-error">@group.ErrorCount</span>
                            }
                            @if (group.WarningCount > 0)
                            {
                                <span class="badge badge-warning">@group.WarningCount</span>
                            }
                        </span>
                    </button>

                    @if (expanded)
                    {
                        <div class="findings-table-wrapper">
                            <table class="findings-table">
                                <thead>
                                    <tr>
                                        <th>Severity</th>
                                        <th>Metric</th>
                                        <th>Method</th>
                                        <th>Type</th>
                                        <th>Line</th>
                                        <th>Value</th>
                                        <th>Threshold</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var f in group.Findings)
                                    {
                                        <tr class="@(f.Severity == Severity.Error ? "row-error" : "row-warning")"
                                            @key="(f.FilePath, f.MethodName, f.LineNumber, f.MetricType)">
                                            <td><span class="badge @(f.Severity == Severity.Error ? "badge-error" : "badge-warning")">@f.Severity</span></td>
                                            <td>@f.MetricType</td>
                                            <td>
                                                <button type="button" class="finding-link" @onclick="() => OnFindingClick.InvokeAsync(f)">
                                                    @f.MethodName
                                                </button>
                                            </td>
                                            <td>@f.ContainingType</td>
                                            <td>@f.LineNumber</td>
                                            <td>@f.Value</td>
                                            <td>@f.Threshold</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            }
        }
    }
}

@code {
    private enum SeverityFilter { Both, ErrorsOnly, WarningsOnly }
    private enum SortOrder { Severity, FilePath, ValueDesc }

    [Parameter]
    public IReadOnlyList<Finding>? Findings { get; set; }

    [Parameter]
    public EventCallback<Finding> OnFindingClick { get; set; }

    [Parameter]
    public EventCallback<string> OnExport { get; set; }

    /// <summary>
    /// Whether the host has a backing AnalysisReport available for JSON/SARIF
    /// export. When false, the JSON/SARIF buttons are hidden so users don't
    /// click no-ops; CSV remains available because it's built inline.
    /// </summary>
    [Parameter]
    public bool CanExport { get; set; }

    private HashSet<string> _expanded = new();
    private SeverityFilter _severityFilter = SeverityFilter.Both;
    private HashSet<MetricType> _metricFilter = new(Enum.GetValues<MetricType>());
    private SortOrder _sortOrder = SortOrder.Severity;
    private IReadOnlyList<Finding>? _lastFindingsRef;

    private sealed record FileGroup(
        string FilePath,
        int ErrorCount,
        int WarningCount,
        IReadOnlyList<Finding> Findings);

    protected override void OnParametersSet()
    {
        // Only reset state when the Findings reference actually changes — protects
        // user-toggled filters across unrelated re-renders.
        if (ReferenceEquals(Findings, _lastFindingsRef)) return;
        _lastFindingsRef = Findings;

        _severityFilter = SeverityFilter.Both;
        _metricFilter = new HashSet<MetricType>(Enum.GetValues<MetricType>());
        _sortOrder = SortOrder.Severity;

        if (Findings is null)
        {
            _expanded = new HashSet<string>();
            return;
        }

        var groups = Findings.GroupBy(f => f.FilePath).ToList();
        _expanded = groups.Count <= 5
            ? new HashSet<string>(groups.Select(g => g.Key))
            : new HashSet<string>();
    }

    private void Toggle(string path)
    {
        if (!_expanded.Add(path))
        {
            _expanded.Remove(path);
        }
    }

    private IEnumerable<Finding> FilteredFindings()
    {
        if (Findings is null) yield break;
        foreach (var f in Findings)
        {
            if (_severityFilter == SeverityFilter.ErrorsOnly && f.Severity != Severity.Error) continue;
            if (_severityFilter == SeverityFilter.WarningsOnly && f.Severity != Severity.Warning) continue;
            if (!_metricFilter.Contains(f.MetricType)) continue;
            yield return f;
        }
    }

    private IReadOnlyList<Finding> SortFindings(IEnumerable<Finding> findings)
    {
        return _sortOrder switch
        {
            SortOrder.Severity => findings
                .OrderBy(f => f.Severity == Severity.Error ? 0 : 1)
                .ThenBy(f => f.LineNumber)
                .ToList(),
            SortOrder.FilePath => findings
                .OrderBy(f => f.FilePath, StringComparer.Ordinal)
                .ThenBy(f => f.LineNumber)
                .ToList(),
            SortOrder.ValueDesc => findings
                .OrderByDescending(f => f.Value)
                .ThenBy(f => f.FilePath, StringComparer.Ordinal)
                .ThenBy(f => f.LineNumber)
                .ToList(),
            _ => findings.ToList()
        };
    }

    private void SetSeverityFilter(SeverityFilter f) => _severityFilter = f;

    private void ToggleMetric(MetricType mt, bool checkedState)
    {
        if (checkedState) _metricFilter.Add(mt);
        else _metricFilter.Remove(mt);
    }

    private static string FilterBtnClass(bool active) =>
        active ? "filter-btn filter-btn-active" : "filter-btn";

    private async Task DownloadCsv()
    {
        var rows = FilteredFindings().ToList();
        if (rows.Count == 0) return;

        var sb = new System.Text.StringBuilder();
        sb.AppendLine("severity,metric,file,line,method,type,value,threshold");
        foreach (var f in rows)
        {
            sb.AppendLine(string.Join(",", new[]
            {
                CsvEscape(f.Severity.ToString()),
                CsvEscape(f.MetricType.ToString()),
                CsvEscape(f.FilePath),
                f.LineNumber.ToString(),
                CsvEscape(f.MethodName),
                CsvEscape(f.ContainingType),
                f.Value.ToString(),
                f.Threshold.ToString(),
            }));
        }

        var stamp = DateTime.UtcNow.ToString("yyyyMMdd-HHmmss");
        var filename = $"cca-findings-{stamp}.csv";
        await JS.InvokeVoidAsync("ccaDownload", filename, sb.ToString(), "text/csv");
    }

    private static string CsvEscape(string value)
    {
        if (string.IsNullOrEmpty(value)) return string.Empty;
        if (value.Contains(',') || value.Contains('"') || value.Contains('\n') || value.Contains('\r'))
        {
            return "\"" + value.Replace("\"", "\"\"") + "\"";
        }
        return value;
    }

    private List<FileGroup> BuildGroups(IReadOnlyList<Finding> findings)
    {
        return findings
            .GroupBy(f => f.FilePath)
            .Select(g => new FileGroup(
                FilePath: g.Key,
                ErrorCount: g.Count(f => f.Severity == Severity.Error),
                WarningCount: g.Count(f => f.Severity == Severity.Warning),
                Findings: SortFindings(g)))
            .OrderByDescending(g => g.ErrorCount)
            .ThenByDescending(g => g.WarningCount)
            .ThenBy(g => g.FilePath, StringComparer.Ordinal)
            .ToList();
    }
}
