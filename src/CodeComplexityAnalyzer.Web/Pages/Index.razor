@page "/"
@using CodeComplexityAnalyzer.Core.Analysis
@using CodeComplexityAnalyzer.Core.Models
@using CodeComplexityAnalyzer.Core.Reporting
@using System.Net.Http.Headers
@using System.Text.Json
@using System.Text.Json.Serialization
@implements IDisposable
@inject HttpClient Http
@inject Microsoft.JSInterop.IJSRuntime JS

<PageTitle>Code Complexity Analyzer</PageTitle>

<h1>Code Complexity Analyzer</h1>

<div class="history-panel-container">
    <button class="history-toggle" @onclick="() => _historyOpen = !_historyOpen" disabled="@(_history.Count == 0)">
        History (@_history.Count)
    </button>
    @if (_historyOpen)
    {
        <div class="history-panel">
            <div class="history-header">
                <span>Recent analyses</span>
                <button class="history-clear" @onclick="ClearHistory">Clear all</button>
            </div>
            @if (_history.Count == 0)
            {
                <div class="history-empty">No saved analyses yet.</div>
            }
            else
            {
                <ul class="history-list">
                    @foreach (var entry in _history)
                    {
                        <li>
                            <button class="history-item" @onclick="() => RestoreFromHistory(entry)">
                                <span class="history-mode">@entry.Mode</span>
                                <span class="history-source">@entry.SourceId</span>
                                <span class="history-counts">
                                    @if (entry.ErrorCount > 0) { <span class="badge badge-error">@entry.ErrorCount</span> }
                                    @if (entry.WarningCount > 0) { <span class="badge badge-warning">@entry.WarningCount</span> }
                                </span>
                                <span class="history-time">@entry.TimestampUtc.ToString("yyyy-MM-dd HH:mm UTC")</span>
                            </button>
                        </li>
                    }
                </ul>
            }
        </div>
    }
</div>

<div class="thresholds">
    <label>Max cyclomatic complexity: <input type="number" min="1" @bind="_maxCc" /></label>
    <label>Max method line count: <input type="number" min="1" @bind="_maxLines" /></label>
    <label>Max parameter count: <input type="number" min="0" @bind="_maxParams" /></label>
    <label>Min maintainability index (0-100): <input type="number" min="0" max="100" @bind="_minMi" /></label>
</div>

<hr />

<h2>Paste C# source</h2>

<textarea rows="20" cols="100" @bind="_sourceCode" placeholder="Paste C# source here..." />

<div>
    <button @onclick="Analyze" disabled="@_isAnalyzing">Analyze</button>
</div>

<FindingsTable Findings="_findings" />

<hr />

<h2>Analyze a GitHub repo</h2>

<div class="github-inputs">
    <div>
        <label>
            GitHub repo URL:
            <input type="text"
                   size="60"
                   @bind="_repoUrl"
                   placeholder="https://github.com/owner/repo" />
        </label>
    </div>
    <div>
        <label>
            Personal access token (optional, raises rate limit):
            <input type="password"
                   size="60"
                   @bind="_githubToken"
                   placeholder="ghp_..." />
        </label>
    </div>
    <div>
        <label>
            Branch (optional, defaults to repo's default branch):
            <input type="text"
                   size="60"
                   @bind="_repoBranch"
                   placeholder="leave empty for default" />
        </label>
    </div>
    <div>
        <button @onclick="AnalyzeRepo" disabled="@_isAnalyzingRepo">Analyze repo</button>
        <button @onclick="CancelRepoAnalysis" disabled="@(!_isAnalyzingRepo)">Cancel</button>
    </div>
</div>

@if (!string.IsNullOrEmpty(_repoStatus))
{
    <p class="repo-status">@_repoStatus</p>
}

<FindingsTable Findings="_repoFindings" />

@code {
    // ── History ───────────────────────────────────────────────────────────────
    private const string HistoryKey = "cca-history-v1";
    private const int HistoryMax = 20;
    private List<HistoryEntry> _history = new();
    private bool _historyOpen = false;

    private static readonly JsonSerializerOptions HistoryJsonOptions = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        Converters = { new JsonStringEnumConverter() },
        WriteIndented = false,
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadHistoryAsync();
        }
    }

    private async Task LoadHistoryAsync()
    {
        try
        {
            var raw = await JS.InvokeAsync<string?>("ccaStorage.get", HistoryKey);
            if (!string.IsNullOrEmpty(raw))
            {
                _history = JsonSerializer.Deserialize<List<HistoryEntry>>(raw, HistoryJsonOptions) ?? new();
            }
        }
        catch
        {
            _history = new();
        }
        StateHasChanged();
    }

    private async Task SaveHistoryAsync()
    {
        try
        {
            var json = JsonSerializer.Serialize(_history, HistoryJsonOptions);
            await JS.InvokeVoidAsync("ccaStorage.set", HistoryKey, json);
        }
        catch { /* localStorage might be full or disabled — fail silently */ }
    }

    private async Task RecordHistory(string mode, string sourceId, List<Finding> findings)
    {
        var entry = new HistoryEntry(
            Id: Guid.NewGuid().ToString(),
            TimestampUtc: DateTime.UtcNow,
            Mode: mode,
            SourceId: sourceId,
            ErrorCount: findings.Count(f => f.Severity == Severity.Error),
            WarningCount: findings.Count(f => f.Severity == Severity.Warning),
            FileCount: findings.Select(f => f.FilePath).Distinct().Count(),
            MaxCc: _maxCc,
            MaxLines: _maxLines,
            MaxParams: _maxParams,
            MinMi: _minMi,
            Findings: findings);

        _history.Insert(0, entry);
        if (_history.Count > HistoryMax)
        {
            _history.RemoveRange(HistoryMax, _history.Count - HistoryMax);
        }
        await SaveHistoryAsync();
    }

    private void RestoreFromHistory(HistoryEntry entry)
    {
        if (entry.Mode == "paste")
        {
            _findings = entry.Findings.ToList();
        }
        else
        {
            _repoFindings = entry.Findings.ToList();
            // SourceId format is "owner/repo@branch" — restore URL and branch separately
            var atIdx = entry.SourceId.IndexOf('@');
            if (atIdx >= 0)
            {
                _repoUrl = $"https://github.com/{entry.SourceId[..atIdx]}";
                _repoBranch = entry.SourceId[(atIdx + 1)..];
            }
            else
            {
                _repoUrl = entry.SourceId;
                _repoBranch = string.Empty;
            }
        }
        _maxCc = entry.MaxCc;
        _maxLines = entry.MaxLines;
        _maxParams = entry.MaxParams;
        _minMi = entry.MinMi;
        _historyOpen = false;
    }

    private async Task ClearHistory()
    {
        _history.Clear();
        await JS.InvokeVoidAsync("ccaStorage.remove", HistoryKey);
    }

    // ── Paste mode ────────────────────────────────────────────────────────────
    private string _sourceCode = string.Empty;
    private int _maxCc = 10;
    private int _maxLines = 60;
    private int _maxParams = 5;
    private int _minMi = 50;
    private List<Finding>? _findings;
    private bool _isAnalyzing;

    private async Task Analyze()
    {
        _isAnalyzing = true;
        try
        {
            var analyzer = new SyntaxAnalyzer();
            var thresholds = new Thresholds(_maxCc, _maxLines, _maxParams, _minMi);
            var metrics = analyzer.AnalyzeSource(_sourceCode ?? string.Empty, "input.cs");

            _findings = metrics
                .SelectMany(m => FindingFactory.Create(m, thresholds))
                .ToList();

            await RecordHistory("paste", "input.cs", _findings.ToList());
        }
        finally
        {
            _isAnalyzing = false;
        }
    }

    // ── GitHub repo mode ──────────────────────────────────────────────────────
    private string _repoUrl = string.Empty;
    private string _githubToken = string.Empty;
    private string _repoBranch = string.Empty;
    private string _repoStatus = string.Empty;
    private List<Finding>? _repoFindings;
    private bool _isAnalyzingRepo;
    private int _failedDownloads;
    private CancellationTokenSource? _repoCts;

    // DTOs for GitHub API responses
    private sealed record GitHubRepo(
        [property: JsonPropertyName("default_branch")] string DefaultBranch);

    private sealed record GitHubTreeResponse(
        [property: JsonPropertyName("tree")] List<GitHubTreeNode> Tree,
        [property: JsonPropertyName("truncated")] bool Truncated = false);

    private sealed record GitHubTreeNode(
        [property: JsonPropertyName("path")] string Path,
        [property: JsonPropertyName("type")] string Type);

    private static readonly HashSet<string> ExcludedDirNames =
        new(StringComparer.OrdinalIgnoreCase) { "bin", "obj", "node_modules" };

    private static bool HasExcludedSegment(string path)
    {
        var segments = path.Split('/', '\\');
        return segments.Any(ExcludedDirNames.Contains);
    }

    private async Task AnalyzeRepo()
    {
        // Cancel any in-flight analysis and start fresh
        _repoCts?.Cancel();
        _repoCts?.Dispose();
        _repoCts = new CancellationTokenSource();
        var ct = _repoCts.Token;

        _repoFindings = null;
        _repoStatus = string.Empty;
        _failedDownloads = 0;
        _isAnalyzingRepo = true;
        StateHasChanged();

        try
        {
            // Parse owner/repo from URL
            if (!TryParseRepoUrl(_repoUrl, out var owner, out var repo))
            {
                _repoStatus = "Invalid URL. Expected: https://github.com/owner/repo";
                return;
            }

            // Resolve branch — use input if provided, otherwise fetch default
            string branch;
            if (!string.IsNullOrWhiteSpace(_repoBranch))
            {
                branch = _repoBranch.Trim();
                _repoStatus = $"Analyzing branch '{branch}'...";
                StateHasChanged();
            }
            else
            {
                _repoStatus = "Fetching repository info...";
                StateHasChanged();
                var repoInfo = await GetJsonAsync<GitHubRepo>(
                    $"https://api.github.com/repos/{owner}/{repo}", ct);
                if (repoInfo is null) return;
                branch = repoInfo.DefaultBranch;
                _repoBranch = branch;  // auto-fill for subsequent analyses
            }

            // Fetch recursive file tree
            _repoStatus = "Fetching file tree...";
            StateHasChanged();

            var tree = await GetJsonAsync<GitHubTreeResponse>(
                $"https://api.github.com/repos/{owner}/{repo}/git/trees/{Uri.EscapeDataString(branch)}?recursive=1", ct);
            if (tree is null) return;

            var csFiles = tree.Tree
                .Where(n => n.Type == "blob"
                            && n.Path.EndsWith(".cs", StringComparison.OrdinalIgnoreCase)
                            && !HasExcludedSegment(n.Path))
                .Select(n => n.Path)
                .ToList();

            if (csFiles.Count == 0)
            {
                _repoStatus = "No .cs files found in repository.";
                return;
            }

            if (tree.Truncated)
            {
                _repoStatus = "Warning: GitHub returned a truncated file tree — results may be incomplete. ";
                StateHasChanged();
            }

            // Analyze each file
            var analyzer = new SyntaxAnalyzer();
            var thresholds = new Thresholds(_maxCc, _maxLines, _maxParams, _minMi);
            var allFindings = new List<Finding>();
            var total = csFiles.Count;

            for (var i = 0; i < csFiles.Count; i++)
            {
                if (ct.IsCancellationRequested)
                {
                    _repoStatus = "Cancelled.";
                    _repoFindings = allFindings.Count > 0 ? allFindings : null;
                    return;
                }

                var path = csFiles[i];
                _repoStatus = $"Analyzing {i + 1}/{total}: {path}";

                if (i % 5 == 0)
                {
                    StateHasChanged();
                    await Task.Yield();
                }

                var rawUrl = $"https://raw.githubusercontent.com/{owner}/{repo}/{Uri.EscapeDataString(branch)}/{path}";
                var content = await FetchTextAsync(rawUrl, ct);
                if (content is null)
                {
                    if (ct.IsCancellationRequested)
                    {
                        _repoStatus = "Cancelled.";
                        _repoFindings = allFindings.Count > 0 ? allFindings : null;
                        return;
                    }
                    _failedDownloads++;
                    continue;
                }

                var metrics = analyzer.AnalyzeSource(content, path);
                allFindings.AddRange(metrics.SelectMany(m => FindingFactory.Create(m, thresholds)));
            }

            _repoFindings = allFindings;
            var actualAnalyzedCount = total - _failedDownloads;
            var failSuffix = _failedDownloads > 0
                ? $" ({_failedDownloads} file(s) could not be downloaded)"
                : string.Empty;
            _repoStatus = allFindings.Count == 0
                ? $"Analyzed {actualAnalyzedCount} files on branch '{branch}' — no findings (all within thresholds).{failSuffix}"
                : $"Analyzed {actualAnalyzedCount} files on branch '{branch}' — {allFindings.Count} finding(s).{failSuffix}";

            await RecordHistory("github", $"{owner}/{repo}@{branch}", allFindings);
        }
        finally
        {
            _isAnalyzingRepo = false;
            StateHasChanged();
        }
    }

    private void CancelRepoAnalysis() => _repoCts?.Cancel();

    public void Dispose()
    {
        _repoCts?.Cancel();
        _repoCts?.Dispose();
    }

    private static bool TryParseRepoUrl(string url, out string owner, out string repo)
    {
        owner = string.Empty;
        repo = string.Empty;

        if (string.IsNullOrWhiteSpace(url)) return false;

        if (!Uri.TryCreate(url.Trim(), UriKind.Absolute, out var uri)) return false;

        if (!uri.Host.Equals("github.com", StringComparison.OrdinalIgnoreCase)) return false;

        var segments = uri.AbsolutePath.Trim('/').Split('/');
        if (segments.Length < 2) return false;

        owner = segments[0];
        repo = segments[1].TrimEnd('/');

        if (repo.EndsWith(".git", StringComparison.OrdinalIgnoreCase))
        {
            repo = repo[..^4];
        }

        return !string.IsNullOrEmpty(owner) && !string.IsNullOrEmpty(repo);
    }

    private async Task<T?> GetJsonAsync<T>(string url, CancellationToken ct = default) where T : class
    {
        using var request = BuildRequest(HttpMethod.Get, url);
        HttpResponseMessage response;
        try
        {
            response = await Http.SendAsync(request, ct);
        }
        catch (OperationCanceledException)
        {
            return null;
        }
        catch (Exception ex)
        {
            _repoStatus = $"Network error: {ex.Message}";
            return null;
        }

        if (!response.IsSuccessStatusCode)
        {
            _repoStatus = FormatHttpError(response);
            return null;
        }

        var json = await response.Content.ReadAsStringAsync(ct);
        try
        {
            return JsonSerializer.Deserialize<T>(json);
        }
        catch (JsonException ex)
        {
            _repoStatus = $"Failed to parse GitHub response: {ex.Message}";
            return null;
        }
    }

    private async Task<string?> FetchTextAsync(string url, CancellationToken ct = default)
    {
        using var request = BuildRequest(HttpMethod.Get, url);
        HttpResponseMessage response;
        try
        {
            response = await Http.SendAsync(request, ct);
        }
        catch (OperationCanceledException)
        {
            return null;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[cca] Download failed for {url}: {ex.Message}");
            return null;
        }

        if (!response.IsSuccessStatusCode)
        {
            Console.WriteLine($"[cca] Download failed for {url}: HTTP {(int)response.StatusCode}");
            return null;
        }

        return await response.Content.ReadAsStringAsync(ct);
    }

    private HttpRequestMessage BuildRequest(HttpMethod method, string url)
    {
        var request = new HttpRequestMessage(method, url);
        request.Headers.Add("User-Agent", "CodeComplexityAnalyzer-Web");
        request.Headers.Add("Accept", "application/vnd.github+json");

        if (!string.IsNullOrWhiteSpace(_githubToken))
        {
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", _githubToken.Trim());
        }

        return request;
    }

    private string FormatHttpError(HttpResponseMessage response)
    {
        var status = (int)response.StatusCode;

        if (status == 404)
            return "Repo not found or private.";

        if (status == 403 || status == 429)
        {
            var remaining = response.Headers.TryGetValues("X-RateLimit-Remaining", out var vals)
                ? vals.FirstOrDefault()
                : null;

            if (remaining == "0" || status == 429)
            {
                var resetEpoch = response.Headers.TryGetValues("X-RateLimit-Reset", out var resets)
                    ? resets.FirstOrDefault()
                    : null;

                var resetTime = string.Empty;
                if (long.TryParse(resetEpoch, out var epoch))
                {
                    var dt = DateTimeOffset.FromUnixTimeSeconds(epoch).ToLocalTime();
                    resetTime = $" Resets at {dt:HH:mm:ss}.";
                }

                return $"GitHub rate limit hit. Provide a personal access token to raise the limit, or wait.{resetTime}";
            }
        }

        return $"GitHub API error: HTTP {status}.";
    }
}
