@page "/"
@using CodeComplexityAnalyzer.Core.Analysis
@using CodeComplexityAnalyzer.Core.Models
@using CodeComplexityAnalyzer.Core.Reporting
@using System.Net.Http.Headers
@using System.Text.Json
@using System.Text.Json.Serialization
@implements IDisposable
@inject HttpClient Http
@inject Microsoft.JSInterop.IJSRuntime JS

<PageTitle>cca · Code Complexity Analyzer</PageTitle>

<Topbar Theme="@_theme"
        ThemeChanged="OnThemeChanged"
        History="@_history"
        OnRestoreHistory="RestoreFromHistory"
        OnClearHistory="ClearHistory" />

<div class="app-shell">
    <section class="hero">
        <h1>Find C# complexity hotspots in seconds.</h1>
        <p class="hero-tagline">
            Paste a C# snippet or analyze any public GitHub repo. <strong>Roslyn-powered, runs entirely in your browser</strong> — no upload, no server.
        </p>
    </section>

    <ThresholdsCard MaxCc="_maxCc" MaxCcChanged="@(v => _maxCc = v)"
                    MaxLines="_maxLines" MaxLinesChanged="@(v => _maxLines = v)"
                    MaxParams="_maxParams" MaxParamsChanged="@(v => _maxParams = v)"
                    MinMi="_minMi" MinMiChanged="@(v => _minMi = v)" />

    <ModeTabs Active="@_activeMode" ActiveChanged="@(v => _activeMode = v)" />

    @* Both panels are always rendered so Monaco's element reference stays stable
       across tab switches; only the inactive panel is hidden via the `hidden` attr. *@
    <div class="card" hidden="@(_activeMode != "paste")">
        <h2 class="section-title">
            <Icon Name="code" Size="16" /> Paste C# source
            <span class="section-title-tag">live</span>
        </h2>

        <div class="drop-zone @(_isDragging ? "dragging" : "")"
             @ondragenter="OnDragEnter"
             @ondragover="OnDragOver"
             @ondragover:preventDefault="true"
             @ondragleave="OnDragLeave"
             @ondrop="OnDrop"
             @ondrop:preventDefault="true">
            <div id="@_editorId" class="monaco-host"></div>
            <div class="drop-hint">Drop .cs files here</div>
        </div>

        <div class="input-actions" style="margin-top: 0.85rem;">
            <button type="button" class="btn btn-primary" @onclick="Analyze" disabled="@_isAnalyzing">
                <Icon Name="play" Size="13" />
                @(_isAnalyzing ? "Analyzing…" : "Analyze")
                <kbd class="kbd-inline">@KbdAnalyze</kbd>
            </button>
            <button type="button" class="btn btn-ghost" @onclick="LoadSampleSnippet"
                    title="Load a deliberately complex C# snippet to demo the analyzer">
                Try a sample
            </button>
            <label class="auto-toggle">
                <input type="checkbox" @bind="_autoAnalyze" />
                Auto-analyze on type
                <span style="color: var(--text-faint); font-size: 0.78rem;">(debounced 400 ms)</span>
            </label>
        </div>

        <FindingsTable Findings="_findings" OnFindingClick="HandleFindingClickPaste" />
    </div>

    <div class="card" hidden="@(_activeMode != "github")">
        <h2 class="section-title">
            <Icon Name="github" Size="16" /> Analyze a GitHub repo
            <span class="section-title-tag">no upload</span>
        </h2>

        <div class="github-inputs">
            <label class="input-field full-width">
                <span class="input-field-label">Repository URL</span>
                <input type="text"
                       @bind="_repoUrl"
                       placeholder="https://github.com/owner/repo" />
                @{
                    var recent = BuildRecentRepoChips();
                }
                @if (recent.Count > 0)
                {
                    <div class="recent-repos">
                        <span class="recent-repos-label">Recent:</span>
                        @foreach (var chip in recent)
                        {
                            <button type="button" class="recent-chip" @key="chip.Source"
                                    @onclick="() => UseRecentRepo(chip)"
                                    title="@chip.Source">
                                <Icon Name="github" Size="11" />
                                <span>@chip.Display</span>
                            </button>
                        }
                    </div>
                }
            </label>
            <label class="input-field">
                <span class="input-field-label">Branch (optional)</span>
                <input type="text"
                       @bind="_repoBranch"
                       placeholder="defaults to repo's default" />
            </label>
            <label class="input-field">
                <span class="input-field-label">Personal access token (optional)</span>
                <input type="password"
                       @bind="_githubToken"
                       placeholder="ghp_… raises rate limit" />
            </label>
        </div>

        <div class="input-actions" style="margin-top: 1rem;">
            <button type="button" class="btn btn-primary" @onclick="AnalyzeRepo" disabled="@_isAnalyzingRepo">
                <Icon Name="play" Size="13" />
                @(_isAnalyzingRepo ? "Analyzing…" : "Analyze repo")
            </button>
            <button type="button" class="btn btn-ghost" @onclick="CancelRepoAnalysis" disabled="@(!_isAnalyzingRepo)">
                <Icon Name="stop" Size="13" />
                Cancel
            </button>
        </div>

        @{
            var repoStatusText = _repoState.ToStatusText();
        }
        <p class="repo-status" role="status" aria-live="polite"
           hidden="@string.IsNullOrEmpty(repoStatusText)">@repoStatusText</p>

        <FindingsTable Findings="_repoFindings" OnFindingClick="HandleFindingClickRepo" />
    </div>
</div>

@code {
    // ── UI state ──────────────────────────────────────────────────────────────
    private string _activeMode = "paste";
    private string _theme = "system";
    private string _modLabel = "Ctrl";
    private string KbdAnalyze => $"{_modLabel}+↵";

    private async Task OnThemeChanged(string theme)
    {
        _theme = theme;
        var effective = await JS.InvokeAsync<string>("ccaTheme.set", _theme);
        if (_editorInitialized)
        {
            await JS.InvokeVoidAsync("ccaMonaco.setTheme", effective == "dark" ? "vs-dark" : "vs");
        }
    }

    // ── History ───────────────────────────────────────────────────────────────
    private const string HistoryKey = "cca-history-v1";
    private const int HistoryMax = 20;
    private List<HistoryEntry> _history = new();

    private static readonly JsonSerializerOptions HistoryJsonOptions = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        Converters = { new JsonStringEnumConverter() },
        WriteIndented = false,
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("ccaTheme.init");
                _theme = await JS.InvokeAsync<string>("ccaTheme.get") ?? "system";
            }
            catch { _theme = "system"; }
            StateHasChanged();
            await LoadHistoryAsync();
            _selfRef = DotNetObjectReference.Create(this);
            var ok = await JS.InvokeAsync<bool>("ccaMonaco.create", _editorId, _sourceCode, _selfRef);
            _editorInitialized = ok;
            try
            {
                await JS.InvokeVoidAsync("ccaShortcuts.attach", _selfRef);
                _modLabel = await JS.InvokeAsync<string>("ccaShortcuts.modLabel") ?? "Ctrl";
                StateHasChanged();
            }
            catch { /* shortcuts are optional */ }
        }
        else if (_editorInitialized && _sourceCode != _lastEditorValue)
        {
            // Push external changes (drag-drop, history restore) into Monaco
            await JS.InvokeVoidAsync("ccaMonaco.setValue", _editorId, _sourceCode);
            _lastEditorValue = _sourceCode;
        }
    }

    [JSInvokable]
    public async Task OnEditorContentChanged(string value)
    {
        _sourceCode = value;
        _lastEditorValue = value;

        if (!_autoAnalyze)
        {
            StateHasChanged();
            return;
        }

        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        _debounceCts = new CancellationTokenSource();
        var ct = _debounceCts.Token;

        StateHasChanged();

        try
        {
            await Task.Delay(DebounceMs, ct);
            if (ct.IsCancellationRequested) return;
            await AnalyzeWithoutHistory();
        }
        catch (TaskCanceledException) { /* expected on debounce */ }
    }

    private async Task LoadHistoryAsync()
    {
        try
        {
            var raw = await JS.InvokeAsync<string?>("ccaStorage.get", HistoryKey);
            if (!string.IsNullOrEmpty(raw))
            {
                _history = JsonSerializer.Deserialize<List<HistoryEntry>>(raw, HistoryJsonOptions) ?? new();
            }
        }
        catch
        {
            _history = new();
        }
        StateHasChanged();
    }

    private async Task SaveHistoryAsync()
    {
        try
        {
            var json = JsonSerializer.Serialize(_history, HistoryJsonOptions);
            await JS.InvokeVoidAsync("ccaStorage.set", HistoryKey, json);
        }
        catch { /* localStorage might be full or disabled — fail silently */ }
    }

    private async Task RecordHistory(string mode, string sourceId, List<Finding> findings)
    {
        var entry = new HistoryEntry(
            Id: Guid.NewGuid().ToString(),
            TimestampUtc: DateTime.UtcNow,
            Mode: mode,
            SourceId: sourceId,
            ErrorCount: findings.Count(f => f.Severity == Severity.Error),
            WarningCount: findings.Count(f => f.Severity == Severity.Warning),
            FileCount: findings.Select(f => f.FilePath).Distinct().Count(),
            MaxCc: _maxCc,
            MaxLines: _maxLines,
            MaxParams: _maxParams,
            MinMi: _minMi,
            Findings: findings);

        _history.Insert(0, entry);
        if (_history.Count > HistoryMax)
        {
            _history.RemoveRange(HistoryMax, _history.Count - HistoryMax);
        }
        await SaveHistoryAsync();
    }

    private void RestoreFromHistory(HistoryEntry entry)
    {
        if (entry.Mode == "paste")
        {
            _findings = entry.Findings.ToList();
            _activeMode = "paste";
        }
        else
        {
            _repoFindings = entry.Findings.ToList();
            var atIdx = entry.SourceId.IndexOf('@');
            if (atIdx >= 0)
            {
                _repoUrl = $"https://github.com/{entry.SourceId[..atIdx]}";
                _repoBranch = entry.SourceId[(atIdx + 1)..];
            }
            else
            {
                _repoUrl = entry.SourceId;
                _repoBranch = string.Empty;
            }
            _activeMode = "github";
        }
        _maxCc = entry.MaxCc;
        _maxLines = entry.MaxLines;
        _maxParams = entry.MaxParams;
        _minMi = entry.MinMi;
    }

    private async Task ClearHistory()
    {
        _history.Clear();
        await JS.InvokeVoidAsync("ccaStorage.remove", HistoryKey);
    }

    // ── Paste mode ────────────────────────────────────────────────────────────
    private string _sourceCode = string.Empty;
    private readonly string _editorId = "cca-editor-" + Guid.NewGuid().ToString("N");
    private DotNetObjectReference<Index>? _selfRef;
    private bool _editorInitialized = false;
    private string _lastEditorValue = string.Empty;
    private bool _isDragging = false;
    private bool _autoAnalyze = true;
    private CancellationTokenSource? _debounceCts;
    private const int DebounceMs = 400;

    private void OnDragEnter(DragEventArgs e) => _isDragging = true;
    private void OnDragOver(DragEventArgs e) => _isDragging = true;
    private void OnDragLeave(DragEventArgs e) => _isDragging = false;

    private async Task OnDrop(DragEventArgs e)
    {
        _isDragging = false;
        var files = await JS.InvokeAsync<FileDescriptor[]>("ccaConsumeDroppedFiles");
        await IngestFiles(files);
    }

    private async Task IngestFiles(FileDescriptor[] files)
    {
        var sb = new System.Text.StringBuilder();
        foreach (var file in files)
        {
            if (!file.Name.EndsWith(".cs", StringComparison.OrdinalIgnoreCase)) continue;
            sb.AppendLine($"// ─── {file.Name} ───");
            sb.AppendLine(file.Content);
            sb.AppendLine();
        }
        if (sb.Length > 0)
        {
            _sourceCode = sb.ToString().TrimEnd();
            StateHasChanged();
        }
        await Task.CompletedTask;
    }

    private sealed record FileDescriptor(string Name, string Content);

    // ── Sample snippet ────────────────────────────────────────────────────────
    private const string SampleSnippet = @"using System;
using System.Collections.Generic;

namespace Demo;

public class OrderProcessor
{
    // Deliberately complex method to demo cca's flagging.
    public string ProcessOrder(string id, int qty, decimal price, bool rush,
                               string couponCode, string region, bool isMember,
                               decimal balance)
    {
        var notes = new List<string>();
        if (qty <= 0) return ""invalid qty"";
        if (price < 0) return ""invalid price"";
        if (string.IsNullOrEmpty(id)) return ""no id"";

        decimal total = qty * price;

        if (rush) total += 10;
        else if (region == ""EU"") total += 5;
        else if (region == ""APAC"") total += 7;
        else if (region == ""NA"") total += 3;

        if (couponCode == ""SAVE10"") total *= 0.9m;
        else if (couponCode == ""SAVE20"") total *= 0.8m;
        else if (couponCode == ""VIP"" && isMember) total *= 0.7m;

        if (balance < total)
        {
            notes.Add(""low balance"");
            if (isMember && balance > total * 0.5m) total *= 0.95m;
            else if (isMember) total *= 0.85m;
            else return ""insufficient funds"";
        }

        for (int i = 0; i < qty; i++)
        {
            if (i % 10 == 0) notes.Add($""checkpoint {i}"");
            if (rush && i > 100) break;
        }

        return total + "" : "" + string.Join("","", notes);
    }
}
";

    private async Task LoadSampleSnippet()
    {
        _sourceCode = SampleSnippet;
        StateHasChanged();
        // OnAfterRenderAsync pushes the new value into Monaco via setValue.
        await Task.CompletedTask;
    }

    // ── Recent repos (derived from history) ───────────────────────────────────
    private sealed record RecentRepoChip(string Source, string Display, string Url, string Branch);

    private List<RecentRepoChip> BuildRecentRepoChips()
    {
        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var chips = new List<RecentRepoChip>();
        foreach (var entry in _history)
        {
            if (entry.Mode != "github") continue;
            if (!seen.Add(entry.SourceId)) continue;

            var atIdx = entry.SourceId.IndexOf('@');
            var ownerRepo = atIdx >= 0 ? entry.SourceId[..atIdx] : entry.SourceId;
            var branch = atIdx >= 0 ? entry.SourceId[(atIdx + 1)..] : string.Empty;

            chips.Add(new RecentRepoChip(
                Source: entry.SourceId,
                Display: ownerRepo,
                Url: $"https://github.com/{ownerRepo}",
                Branch: branch));

            if (chips.Count >= 5) break;
        }
        return chips;
    }

    private void UseRecentRepo(RecentRepoChip chip)
    {
        _repoUrl = chip.Url;
        _repoBranch = chip.Branch;
    }

    private int _maxCc = 10;
    private int _maxLines = 60;
    private int _maxParams = 5;
    private int _minMi = 50;
    private List<Finding>? _findings;
    private bool _isAnalyzing;

    private async Task Analyze() => await AnalyzeCore(recordHistory: true);

    private async Task AnalyzeWithoutHistory() => await AnalyzeCore(recordHistory: false);

    private async Task AnalyzeCore(bool recordHistory)
    {
        _isAnalyzing = true;
        try
        {
            var analyzer = new SyntaxAnalyzer();
            var thresholds = new Thresholds(_maxCc, _maxLines, _maxParams, _minMi);
            var metrics = analyzer.AnalyzeSource(_sourceCode ?? string.Empty, "input.cs");

            _findings = metrics
                .SelectMany(m => FindingFactory.Create(m, thresholds))
                .ToList();

            if (recordHistory && _findings.Count > 0)
            {
                await RecordHistory("paste", "input.cs", _findings.ToList());
            }
        }
        finally
        {
            _isAnalyzing = false;
            StateHasChanged();
        }
    }

    // ── GitHub repo mode ──────────────────────────────────────────────────────
    private string _repoUrl = string.Empty;
    private string _githubToken = string.Empty;
    private string _repoBranch = string.Empty;
    private List<Finding>? _repoFindings;
    private RepoAnalysisState _repoState = new RepoAnalysisState.Idle();
    private CancellationTokenSource? _repoCts;

    private bool _isAnalyzingRepo => _repoState.IsRunning();

    private sealed record GitHubRepo(
        [property: JsonPropertyName("default_branch")] string DefaultBranch);

    private sealed record GitHubTreeResponse(
        [property: JsonPropertyName("tree")] List<GitHubTreeNode> Tree,
        [property: JsonPropertyName("truncated")] bool Truncated = false);

    private sealed record GitHubTreeNode(
        [property: JsonPropertyName("path")] string Path,
        [property: JsonPropertyName("type")] string Type);

    private static readonly HashSet<string> ExcludedDirNames =
        new(StringComparer.OrdinalIgnoreCase) { "bin", "obj", "node_modules" };

    private static bool HasExcludedSegment(string path)
    {
        var segments = path.Split('/', '\\');
        return segments.Any(ExcludedDirNames.Contains);
    }

    private async Task AnalyzeRepo()
    {
        _repoCts?.Cancel();
        _repoCts?.Dispose();
        _repoCts = new CancellationTokenSource();
        var ct = _repoCts.Token;

        _repoFindings = null;
        _repoState = new RepoAnalysisState.Resolving(string.Empty);
        StateHasChanged();

        try
        {
            if (!TryParseRepoUrl(_repoUrl, out var owner, out var repo))
            {
                _repoState = new RepoAnalysisState.Failed(
                    "Invalid URL. Expected: https://github.com/owner/repo");
                return;
            }

            var branch = await ResolveBranchAsync(owner, repo, ct);
            if (branch is null) return;

            var csFiles = await FetchTreeAsync(owner, repo, branch, ct);
            if (csFiles is null) return;

            if (csFiles.Count == 0)
            {
                _repoState = new RepoAnalysisState.Failed("No .cs files found in repository.");
                return;
            }

            await AnalyzeFilesAsync(owner, repo, branch, csFiles, ct);
        }
        finally
        {
            StateHasChanged();
        }
    }

    private async Task<string?> ResolveBranchAsync(string owner, string repo, CancellationToken ct)
    {
        if (!string.IsNullOrWhiteSpace(_repoBranch))
        {
            var branch = _repoBranch.Trim();
            _repoState = new RepoAnalysisState.Fetching(branch);
            StateHasChanged();
            return branch;
        }

        _repoState = new RepoAnalysisState.Resolving("Fetching repository info...");
        StateHasChanged();
        var repoInfo = await GetJsonAsync<GitHubRepo>(
            $"https://api.github.com/repos/{owner}/{repo}", ct);
        if (repoInfo is null) return null;

        _repoBranch = repoInfo.DefaultBranch;
        return repoInfo.DefaultBranch;
    }

    private async Task<List<string>?> FetchTreeAsync(
        string owner, string repo, string branch, CancellationToken ct)
    {
        _repoState = new RepoAnalysisState.Resolving("Fetching file tree...");
        StateHasChanged();

        var tree = await GetJsonAsync<GitHubTreeResponse>(
            $"https://api.github.com/repos/{owner}/{repo}/git/trees/{Uri.EscapeDataString(branch)}?recursive=1", ct);
        if (tree is null) return null;

        return tree.Tree
            .Where(n => n.Type == "blob"
                        && n.Path.EndsWith(".cs", StringComparison.OrdinalIgnoreCase)
                        && !HasExcludedSegment(n.Path))
            .Select(n => n.Path)
            .ToList();
    }

    private async Task AnalyzeFilesAsync(
        string owner, string repo, string branch, List<string> csFiles, CancellationToken ct)
    {
        var analyzer = new SyntaxAnalyzer();
        var thresholds = new Thresholds(_maxCc, _maxLines, _maxParams, _minMi);
        var allFindings = new List<Finding>();
        var failedDownloads = 0;
        var total = csFiles.Count;

        for (var i = 0; i < csFiles.Count; i++)
        {
            if (ct.IsCancellationRequested)
            {
                _repoFindings = allFindings.Count > 0 ? allFindings : null;
                _repoState = new RepoAnalysisState.Cancelled();
                return;
            }

            var path = csFiles[i];
            _repoState = new RepoAnalysisState.Analyzing(i + 1, total, path, failedDownloads);

            if (i % 5 == 0)
            {
                StateHasChanged();
                await Task.Yield();
            }

            var rawUrl = $"https://raw.githubusercontent.com/{owner}/{repo}/{Uri.EscapeDataString(branch)}/{path}";
            var content = await FetchTextAsync(rawUrl, ct);
            if (content is null)
            {
                if (ct.IsCancellationRequested)
                {
                    _repoFindings = allFindings.Count > 0 ? allFindings : null;
                    _repoState = new RepoAnalysisState.Cancelled();
                    return;
                }
                failedDownloads++;
                continue;
            }

            var metrics = analyzer.AnalyzeSource(content, path);
            allFindings.AddRange(metrics.SelectMany(m => FindingFactory.Create(m, thresholds)));
        }

        _repoFindings = allFindings;
        _repoState = new RepoAnalysisState.Completed(
            Branch: branch,
            Analyzed: total - failedDownloads,
            FailedDownloads: failedDownloads,
            FindingsCount: allFindings.Count);

        await RecordHistory("github", $"{owner}/{repo}@{branch}", allFindings);
    }

    private void CancelRepoAnalysis() => _repoCts?.Cancel();

    // ── Click-to-jump ─────────────────────────────────────────────────────────
    private async Task HandleFindingClickPaste(Finding f)
    {
        if (!_editorInitialized) return;
        await JS.InvokeVoidAsync("ccaMonaco.revealLine", _editorId, f.LineNumber);
    }

    private async Task HandleFindingClickRepo(Finding f)
    {
        if (!TryParseRepoUrl(_repoUrl, out var owner, out var repo)) return;
        var branch = string.IsNullOrWhiteSpace(_repoBranch) ? "main" : _repoBranch.Trim();
        var escapedPath = string.Join("/", f.FilePath.Split('/', '\\').Select(Uri.EscapeDataString));
        var url = $"https://github.com/{owner}/{repo}/blob/{Uri.EscapeDataString(branch)}/{escapedPath}#L{f.LineNumber}";
        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    // ── Keyboard shortcuts ────────────────────────────────────────────────────
    [JSInvokable]
    public async Task OnShortcutAnalyze()
    {
        if (_activeMode == "paste")
        {
            if (!_isAnalyzing) await Analyze();
        }
        else
        {
            if (!_isAnalyzingRepo) await AnalyzeRepo();
        }
    }

    [JSInvokable]
    public Task OnShortcutCancel()
    {
        if (_isAnalyzingRepo) _repoCts?.Cancel();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public async Task OnShortcutToggleTheme()
    {
        // light → dark → system → light …
        var next = _theme switch
        {
            "light" => "dark",
            "dark" => "system",
            _ => "light",
        };
        await OnThemeChanged(next);
        StateHasChanged();
    }

    public void Dispose()
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        _repoCts?.Cancel();
        _repoCts?.Dispose();
        _selfRef?.Dispose();
        if (_editorInitialized)
        {
            // Best-effort dispose — fire-and-forget since Dispose is sync
            _ = JS.InvokeVoidAsync("ccaMonaco.dispose", _editorId);
            _ = JS.InvokeVoidAsync("ccaShortcuts.detach");
        }
    }

    private static bool TryParseRepoUrl(string url, out string owner, out string repo)
    {
        owner = string.Empty;
        repo = string.Empty;

        if (string.IsNullOrWhiteSpace(url)) return false;

        if (!Uri.TryCreate(url.Trim(), UriKind.Absolute, out var uri)) return false;

        if (!uri.Host.Equals("github.com", StringComparison.OrdinalIgnoreCase)) return false;

        var segments = uri.AbsolutePath.Trim('/').Split('/');
        if (segments.Length < 2) return false;

        owner = segments[0];
        repo = segments[1].TrimEnd('/');

        if (repo.EndsWith(".git", StringComparison.OrdinalIgnoreCase))
        {
            repo = repo[..^4];
        }

        return !string.IsNullOrEmpty(owner) && !string.IsNullOrEmpty(repo);
    }

    private async Task<T?> GetJsonAsync<T>(string url, CancellationToken ct = default) where T : class
    {
        using var request = BuildRequest(HttpMethod.Get, url);
        HttpResponseMessage response;
        try
        {
            response = await Http.SendAsync(request, ct);
        }
        catch (OperationCanceledException)
        {
            _repoState = new RepoAnalysisState.Cancelled();
            return null;
        }
        catch (Exception ex)
        {
            _repoState = new RepoAnalysisState.Failed($"Network error: {ex.Message}");
            return null;
        }

        if (!response.IsSuccessStatusCode)
        {
            _repoState = new RepoAnalysisState.Failed(FormatHttpError(response));
            return null;
        }

        var json = await response.Content.ReadAsStringAsync(ct);
        try
        {
            return JsonSerializer.Deserialize<T>(json);
        }
        catch (JsonException ex)
        {
            _repoState = new RepoAnalysisState.Failed($"Failed to parse GitHub response: {ex.Message}");
            return null;
        }
    }

    private async Task<string?> FetchTextAsync(string url, CancellationToken ct = default)
    {
        using var request = BuildRequest(HttpMethod.Get, url);
        HttpResponseMessage response;
        try
        {
            response = await Http.SendAsync(request, ct);
        }
        catch (OperationCanceledException)
        {
            return null;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[cca] Download failed for {url}: {ex.Message}");
            return null;
        }

        if (!response.IsSuccessStatusCode)
        {
            Console.WriteLine($"[cca] Download failed for {url}: HTTP {(int)response.StatusCode}");
            return null;
        }

        return await response.Content.ReadAsStringAsync(ct);
    }

    private HttpRequestMessage BuildRequest(HttpMethod method, string url)
    {
        var request = new HttpRequestMessage(method, url);
        request.Headers.Add("User-Agent", "CodeComplexityAnalyzer-Web");
        request.Headers.Add("Accept", "application/vnd.github+json");

        if (!string.IsNullOrWhiteSpace(_githubToken))
        {
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", _githubToken.Trim());
        }

        return request;
    }

    private string FormatHttpError(HttpResponseMessage response)
    {
        var status = (int)response.StatusCode;

        if (status == 404)
            return "Repo not found or private.";

        if (status == 403 || status == 429)
        {
            var remaining = response.Headers.TryGetValues("X-RateLimit-Remaining", out var vals)
                ? vals.FirstOrDefault()
                : null;

            if (remaining == "0" || status == 429)
            {
                var resetEpoch = response.Headers.TryGetValues("X-RateLimit-Reset", out var resets)
                    ? resets.FirstOrDefault()
                    : null;

                var resetTime = string.Empty;
                if (long.TryParse(resetEpoch, out var epoch))
                {
                    var dt = DateTimeOffset.FromUnixTimeSeconds(epoch).ToLocalTime();
                    resetTime = $" Resets at {dt:HH:mm:ss}.";
                }

                return $"GitHub rate limit hit. Provide a personal access token to raise the limit, or wait.{resetTime}";
            }
        }

        return $"GitHub API error: HTTP {status}.";
    }
}
